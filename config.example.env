# ===================== QQ 邮箱 SMTP (默认) =====================
# 注意:SMTP_PASSWORD 是 QQ 邮箱"授权码",不是 QQ 密码!
#       生成方法: 登录 mail.qq.com → 设置 → 账户 → 开启 SMTP/IMAP → 生成授权码
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=728962465@qq.com
SMTP_PASSWORD=粘贴你的QQ邮箱授权码到这里

EMAIL_FROM=728962465@qq.com
EMAIL_TO=728962465@qq.com

# ===================== 选股参数 =====================
# 蓝梯>黄梯 严格度
#   false (默认): 上下沿都更高 (UP1>UP2 AND DW1>DW2)
#   true (严格):  蓝梯下沿>黄梯上沿 (完全分离,信号更稀少)
STRICT_BLUE_ABOVE=false

# 信号回溯窗口
# DAILY_LOOKBACK_BARS=3 表示日线 DXDX 在最近 3 根日 K 内触发即算
# H4_LOOKBACK_BARS=2    表示 4H DXDX 在最近 2 根 4H K 内触发即算
DAILY_LOOKBACK_BARS=3
H4_LOOKBACK_BARS=2

# 并发抓取线程数 (8-16 比较安全,太高会被 Yahoo 限速)
MAX_WORKERS=8

# ===================== Gmail 切换提示 =====================
# 如果想用 Gmail,改成:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_PASSWORD=Gmail的应用专用密码 (App Password,不是登录密码)
